def alphabeta(depth, alpha, beta, isMax):
    if depth == 0:
        return 1

    if isMax:
        value = -999
        value = max(value, alphabeta(depth-1, alpha, beta, False))
        alpha = max(alpha, value)
        return value
    else:
        value = 999
        value = min(value, alphabeta(depth-1, alpha, beta, True))
        beta = min(beta, value)
        return value

print(alphabeta(3,-999,999,True))
